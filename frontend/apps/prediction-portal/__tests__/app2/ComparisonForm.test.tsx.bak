import { describe, it, expect, vi, beforeEach } from 'vitest';
import { render, screen } from '@testing-library/react';
import userEvent from '@testing-library/user-event';
import { ComparisonForm } from '@/components/app1/ComparisonForm';

vi.mock('@/lib/app1/client', () => ({
  batchEstimate: vi.fn(),
  ApiClientError: class extends Error {
    constructor(message: string, public code: number, public httpStatus: number) {
      super(message);
      this.name = 'ApiClientError';
    }
  },
}));

import { batchEstimate } from '@/lib/app1/client';
const mockBatchEstimate = batchEstimate as ReturnType<typeof vi.fn>;

const MOCK_RESULTS = {
  predictions: [
    { predicted_price: 680000, currency: 'USD', input_features: { square_footage: 3000, bedrooms: 5, bathrooms: 3.5, year_built: 2020, lot_size: 10000, distance_to_city_center: 8, school_rating: 9 }, model_version: 'LinearRegression', timestamp: '2026-06-15T10:30:00Z', rank: 1 },
    { predicted_price: 425000, currency: 'USD', input_features: { square_footage: 2000, bedrooms: 3, bathrooms: 2, year_built: 2010, lot_size: 5000, distance_to_city_center: 5.2, school_rating: 8 }, model_version: 'LinearRegression', timestamp: '2026-06-15T10:30:00Z', rank: 2 },
  ],
  model_version: 'LinearRegression',
};

describe('ComparisonForm', () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  it('renders with 2 property slots by default', () => {
    render(<ComparisonForm />);
    const forms = screen.getAllByTestId('comparison-slot');
    expect(forms).toHaveLength(2);
  });

  it('allows adding up to 5 property slots', async () => {
    const user = userEvent.setup();
    render(<ComparisonForm />);

    for (let i = 2; i < 5; i++) {
      await user.click(screen.getByTestId('btn-add-slot'));
      expect(screen.getAllByTestId('comparison-slot')).toHaveLength(i + 1);
    }

    // Add button should be hidden at 5
    expect(screen.queryByTestId('btn-add-slot')).not.toBeInTheDocument();
  });

  it('allows removing a property slot (minimum 2)', async () => {
    const user = userEvent.setup();
    render(<ComparisonForm />);

    // Add 2 more
    await user.click(screen.getByTestId('btn-add-slot'));
    await user.click(screen.getByTestId('btn-add-slot'));
    expect(screen.getAllByTestId('comparison-slot')).toHaveLength(4);

    // Remove 2
    const removeButtons = screen.getAllByTestId('btn-remove-slot');
    await user.click(removeButtons[0]);
    await user.click(screen.getAllByTestId('btn-remove-slot')[0]);
    expect(screen.getAllByTestId('comparison-slot')).toHaveLength(2);
  });

  it('calls batchEstimate with all properties and shows results', async () => {
    mockBatchEstimate.mockResolvedValueOnce(MOCK_RESULTS);

    const user = userEvent.setup();
    render(<ComparisonForm />);

    // Fill both slots with valid data
    const slots = screen.getAllByTestId('comparison-slot');
    for (const slot of slots) {
      const inputs = slot.querySelectorAll('input');
      const values = ['2000', '3', '2', '2010', '5000', '5', '8'];
      for (let i = 0; i < inputs.length; i++) {
        await user.type(inputs[i], values[i]);
      }
    }

    await user.click(screen.getByTestId('btn-compare'));

    expect(mockBatchEstimate).toHaveBeenCalledOnce();
    expect(screen.getByTestId('comparison-results')).toBeInTheDocument();
  });

  it('shows validation error if any slot is incomplete', async () => {
    const user = userEvent.setup();
    render(<ComparisonForm />);

    // Only fill first slot
    const firstSlot = screen.getAllByTestId('comparison-slot')[0];
    const inputs = firstSlot.querySelectorAll('input');
    await user.type(inputs[0], '2000');

    await user.click(screen.getByTestId('btn-compare'));

    expect(screen.getByTestId('error-message')).toHaveTextContent(/fill all/i);
    expect(mockBatchEstimate).not.toHaveBeenCalled();
  });
});
